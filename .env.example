# ===========================================
# TUNESTRADE - Environment Configuration
# ===========================================

# Environment: development | staging | production
ENVIRONMENT=development
DEBUG=false

# Log Levels: DEBUG (todos), INFO (padrão), WARNING (avisos+erros), ERROR (só erros)
LOG_LEVEL=INFO

# ===========================================
# Railway Deployment
# ===========================================
RAILWAY_FAST_MODE=false

# ===========================================
# API Configuration
# ===========================================
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# JWT Configuration
SECRET_KEY=change-this-to-a-secure-random-string-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===========================================
# Database
# SQLite: sqlite+aiosqlite:///./tunestrade.db
# PostgreSQL: postgresql+asyncpg://user:pass@host:5432/dbname
# ===========================================
DATABASE_URL=sqlite+aiosqlite:///./tunestrade.db

# ===========================================
# REDIS - Security & Session Persistence
# ===========================================
# Enable Redis for persistent sessions, token blacklist and audit logging
# If disabled, system uses in-memory fallback (data lost on restart)
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=your-password-here  # Opcional

# Cache TTL in seconds (default: 5 min)
REDIS_CACHE_TTL=300

# ===========================================
# Rate Limiting
# ===========================================
RATE_LIMIT_PER_MINUTE=200
RATE_LIMIT_PER_MINUTE_AUTH=500

# ===========================================
# CORS Configuration
# ===========================================
CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=true

# ===========================================
# Telegram Notifications
# ===========================================
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_ENABLED=false

# ===========================================
# PocketOption Configuration
# ===========================================
POCKETOPTION_MAINTENANCE_CHECK_ENABLED=true
POCKETOPTION_MAINTENANCE_CHECK_URL=https://pocketoption.com/pt/cabinet/demo-quick-high-low/
POCKETOPTION_MAINTENANCE_CHECK_INTERVAL=60
POCKETOPTION_MAINTENANCE_CHECK_TIMEOUT=10

# ===========================================
# Risk Management
# ===========================================
MAX_TRADES_PER_DAY=20
MAX_TRADES_SIMULTANEOUS=5
MAX_TRADE_AMOUNT=100.0
MAX_DAILY_LOSS_PERCENT=5.0
MIN_SIGNAL_CONFIDENCE=0.7

# ===========================================
# Data Collector
# ===========================================
DATA_COLLECTOR_ENABLED=true
