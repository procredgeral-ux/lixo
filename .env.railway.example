# Variáveis de Ambiente - Railway
# Copie estas variáveis para o dashboard do Railway (Settings > Variables)

# ============================================
# CONFIGURAÇÃO BÁSICA
# ============================================
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
RAILWAY_FAST_MODE=false
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# ============================================
# SEGURANÇA (GERE UMA NOVA PARA PRODUÇÃO!)
# ============================================
SECRET_KEY=tunestrade-production-secret-key-2024-secure-railway-app-32chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# DATABASE (Usar as variáveis automáticas do Railway)
# NÃO MUDE - Railway preenche automaticamente
# DATABASE_URL=${{Postgres.DATABASE_URL}}
# ============================================

# ============================================
# REDIS (Usar as variáveis automáticas do Railway)
# REDIS_URL será preenchida automaticamente pelo Railway
# ============================================
REDIS_ENABLED=true
REDIS_CACHE_TTL=300

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_MINUTE_AUTH=300

# ============================================
# CORS
# ============================================
CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=true

# ============================================
# TELEGRAM (ESSENCIAL PARA NOTIFICAÇÕES)
# ============================================
TELEGRAM_BOT_TOKEN=8209575841:AAEp4EJAblEHF2NTqkUIJqA-oII5Y4hs3eI
TELEGRAM_ENABLED=true

# ============================================
# POCKETOPTION CONFIG
# ============================================
POCKETOPTION_MAINTENANCE_CHECK_ENABLED=true
POCKETOPTION_MAINTENANCE_CHECK_URL=https://pocketoption.com/pt/cabinet/demo-quick-high-low/
POCKETOPTION_MAINTENANCE_CHECK_INTERVAL=60
POCKETOPTION_MAINTENANCE_CHECK_TIMEOUT=10

# ============================================
# RISK MANAGEMENT
# ============================================
MAX_TRADES_PER_DAY=20
MAX_TRADES_SIMULTANEOUS=5
MAX_TRADE_AMOUNT=100.0
MAX_DAILY_LOSS_PERCENT=5.0
MIN_SIGNAL_CONFIDENCE=0.7

# ============================================
# DATA COLLECTOR
# ============================================
DATA_COLLECTOR_ENABLED=true

# ============================================
# LOGGING
# ============================================
LOG_FILE=logs/autotrade.log
LOG_ROTATION=1 day
LOG_RETENTION=7 days
LOG_FORMAT="{time:YYYY-MM-DD HH:mm:ss} | {level} | {name}:{function}:{line} | {message}"

# ============================================
# MONITORING
# ============================================
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# ============================================
# CELERY (desabilitado por padrão)
# ============================================
CELERY_ENABLED=false
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
