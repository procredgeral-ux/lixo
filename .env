ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
RAILWAY_FAST_MODE=true
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
SECRET_KEY=dev-secret-key-change-for-production-min-32-chars

# PostgreSQL Railway (Private Network)
DATABASE_URL=postgresql+asyncpg://postgres:cDUdtonjYJPsaVtRkXwHrbzQFwDsmbUM@postgres-4che.railway.internal:5432/railway?sslmode=require

# PostgreSQL Railway (Public - fallback)
# DATABASE_PUBLIC_URL=postgresql+asyncpg://postgres:cDUdtonjYJPsaVtRkXwHrbzQFwDsmbUM@shortline.proxy.rlwy.net:56511/railway?sslmode=require

POSTGRES_USER=postgres
POSTGRES_PASSWORD=cDUdtonjYJPsaVtRkXwHrbzQFwDsmbUM
POSTGRES_DB=railway
PGHOST=postgres-4che.railway.internal
PGPORT=5432

# Redis (disabled)
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_TTL=300

# Auth
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate Limits
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_MINUTE_AUTH=300

# CORS
CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=true

# Telegram
TELEGRAM_BOT_TOKEN=8209575841:AAEp4EJAblEHF2NTqkUIJqA-oII5Y4hs3eI
TELEGRAM_ENABLED=true

# PocketOption
POCKETOPTION_MAINTENANCE_CHECK_ENABLED=true
POCKETOPTION_MAINTENANCE_CHECK_URL=https://pocketoption.com/pt/cabinet/demo-quick-high-low/
POCKETOPTION_MAINTENANCE_CHECK_INTERVAL=60
POCKETOPTION_MAINTENANCE_CHECK_TIMEOUT=10

# Trading Limits
MAX_TRADES_PER_DAY=20
MAX_TRADES_SIMULTANEOUS=5
MAX_TRADE_AMOUNT=100.0
MAX_DAILY_LOSS_PERCENT=5.0
MIN_SIGNAL_CONFIDENCE=0.7

# Data Collector
DATA_COLLECTOR_ENABLED=true
MAX_ASSETS_PER_ACCOUNT=10

# Logging
LOG_FILE=logs/autotrade.log
LOG_ROTATION=1 day
LOG_RETENTION=7 days
LOG_FORMAT={time:YYYY-MM-DD HH:mm:ss} | {level} | {name}:{function}:{line} | {message}

# Prometheus
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# Celery
CELERY_ENABLED=false
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
