# ============================================================
# AutoTrade - Complete Environment Configuration
# ============================================================
# TWO ENVIRONMENTS: development | production
# ONE VARIABLE TO RULE THEM ALL: ENVIRONMENT
#
# SWITCH BETWEEN ENVIRONMENTS:
#   ENVIRONMENT=development  → Uses LOCAL database and settings
#   ENVIRONMENT=production   → Uses RAILWAY database and settings
# ============================================================

# ==================== SELECT ENVIRONMENT ====================
# ONLY CHANGE THIS LINE:
ENVIRONMENT=production


# #####################################################################
# DEVELOPMENT ENVIRONMENT CONFIGURATION (LOCAL)
# #####################################################################
# Used when ENVIRONMENT=development

# Development Database
DB_DEV_HOST=localhost
DB_DEV_PORT=5432
DB_DEV_NAME=tunestrade
DB_DEV_USER=tunestrade
DB_DEV_PASSWORD=tunestrade
DB_DEV_SSL=false

# Development API
API_DEV_HOST=0.0.0.0
API_DEV_PORT=8000
API_DEV_DEBUG=true
API_DEV_LOG_LEVEL=DEBUG

# Development Security
SECRET_KEY_DEV=dev-secret-key-local-development-only-not-for-production

# Development Features
TELEGRAM_DEV_ENABLED=false
DATA_COLLECTOR_DEV_ENABLED=false
REDIS_DEV_ENABLED=false


# #####################################################################
# PRODUCTION ENVIRONMENT CONFIGURATION (RAILWAY)
# #####################################################################
# Used when ENVIRONMENT=production

# Production Database (Railway)
DB_PROD_URL=postgresql+asyncpg://postgres:cDUdtonjYJPsaVtRkXwHrbzQFwDsmbUM@shortline.proxy.rlwy.net:56511/railway?sslmode=require
DB_PROD_SSL=true

# Production API
API_PROD_HOST=0.0.0.0
API_PROD_PORT=8000
API_PROD_DEBUG=false
API_PROD_LOG_LEVEL=INFO

# Production Security - CHANGE THIS!
SECRET_KEY_PROD=change-this-to-a-secure-key-min-32-characters-long

# Production Features
TELEGRAM_PROD_ENABLED=true
DATA_COLLECTOR_PROD_ENABLED=true
REDIS_PROD_ENABLED=true


# #####################################################################
# RAILWAY-SPECIFIC (Auto-injected by Railway platform)
# Leave these commented - Railway provides them automatically
# #####################################################################
# DATABASE_URL (provided by Railway)
# DATABASE_PUBLIC_URL (provided by Railway)
# RAILWAY_PROJECT_ID (provided by Railway)
# RAILWAY_SERVICE_ID (provided by Railway)
# RAILWAY_ENVIRONMENT (provided by Railway)


# #####################################################################
# SHARED CONFIGURATION (Used in BOTH environments)
# #####################################################################

# API
API_PREFIX=/api/v1

# Authentication
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate Limits
RATE_LIMIT_PER_MINUTE=200
RATE_LIMIT_PER_MINUTE_AUTH=500

# CORS
CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=true

# Telegram (works in both)
TELEGRAM_BOT_TOKEN=8209575841:AAEp4EJAblEHF2NTqkUIJqA-oII5Y4hs3eI

# PocketOption
POCKETOPTION_MAINTENANCE_CHECK_ENABLED=true
POCKETOPTION_MAINTENANCE_CHECK_URL=https://pocketoption.com/pt/cabinet/demo-quick-high-low/
POCKETOPTION_MAINTENANCE_CHECK_INTERVAL=60
POCKETOPTION_MAINTENANCE_CHECK_TIMEOUT=10

# Trading Limits
MAX_TRADES_PER_DAY=20
MAX_TRADES_SIMULTANEOUS=5
MAX_TRADE_AMOUNT=100.0
MAX_DAILY_LOSS_PERCENT=5.0
MIN_SIGNAL_CONFIDENCE=0.7

# Data Collection
MAX_ASSETS_PER_ACCOUNT=10

# Redis (shared settings)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_TTL=300

# Logging
LOG_FILE=logs/autotrade.log
LOG_ROTATION=1 day
LOG_RETENTION=7 days

# Monitoring
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# Celery
CELERY_ENABLED=false
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2


# ============================================================
# QUICK REFERENCE
# ============================================================
# 
# TO USE LOCAL DEVELOPMENT:
#   1. Set: ENVIRONMENT=development
#   2. Ensure PostgreSQL is running on localhost:5432
#   3. Database 'tunestrade' exists
#   4. Run: python run.py
#
# TO USE RAILWAY PRODUCTION:
#   1. Set: ENVIRONMENT=production
#   2. Run: python run.py
#   3. Connects automatically to Railway database
#
# SETUP LOCAL DATABASE:
#   1. Install PostgreSQL
#   2. Create database:
#      CREATE DATABASE tunestrade;
#   3. Grant permissions:
#      GRANT ALL PRIVILEGES ON DATABASE tunestrade TO postgres;
#
# ============================================================
